---
const plans = [
    {
        name: "Trial",
        price: "Gratis",
        duration: "7-14 días",
        description: "Prueba el núcleo de TrimmOS y conoce el flujo del sistema.",
        features: ["Agenda básica", "1 módulo a elegir", "Hasta 2 integrantes del equipo", "Explora el panel y flujo principal"],
        buttonText: "Empezar prueba",
        highlight: false
    },
    {
        name: "Essential",
        price: "$299",
        duration: "mes",
        description: "Pensado para negocios que buscan orden y control total sin complicaciones.",
        features: ["Módulo especializado", "Servicios y staff", "Agenda completa 24/7", "Gestión operativa del negocio"],
        buttonText: "Activar Plan",
        highlight: false
    },
    {
        name: "Pro",
        price: "$499",
        duration: "mes",
        description: "La mejor opción para negocios que quieren operar en serio y crecer.",
        features: ["Barber + Beauty", "Panel más completo", "Operación centralizada", "Base lista para reportes y crecimiento"],
        buttonText: "Activar Pro",
        highlight: true
    }
];
---

<section id="pricing" class="py-24 bg-[#0a0a0c]">
    <div class="max-w-6xl mx-auto px-4">
        <div class="grid md:grid-cols-3 gap-8 items-start">
            {plans.map((plan) => (
                <div class={`relative p-8 rounded-3xl bg-[#16161a] border transition-all duration-300 hover:translate-y-[-8px] ${plan.highlight ? 'border-purple-600 shadow-[0_0_30px_rgba(147,51,234,0.2)] scale-105 z-10' : 'border-gray-800'}`}>
                {plan.highlight && (
                    <span class="absolute -top-4 left-1/2 -translate-x-1/2 bg-purple-600 text-white text-xs font-bold px-4 py-1 rounded-full uppercase tracking-wider">
                    Más recomendado
                    </span>
                )}
                <h3 class="text-2xl font-bold mb-2">{plan.name}</h3>
                <p class="text-gray-400 text-sm mb-6 h-10">{plan.description}</p>
                <div class="mb-8">
                    <span class="text-4xl font-extrabold">{plan.price}</span>
                    <span class="text-gray-500 ml-1 italic">{plan.duration}</span>
                </div>
                <ul class="space-y-4 mb-8">
                    {plan.features.map((feature) => (
                    <li class="flex items-start text-sm text-gray-300 leading-tight">
                        <svg class="w-5 h-5 text-purple-500 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        {feature}
                    </li>
                    ))}
                </ul>
                <button class={`w-full py-4 rounded-2xl font-bold transition-all ${plan.highlight ? 'bg-purple-600 hover:bg-purple-700 shadow-lg shadow-purple-900/20' : 'bg-[#252529] hover:bg-[#323238]'}`}>
                    {plan.buttonText}
                </button>
                </div>
            ))}
        </div>
        
        <!-- Frase de respaldo de ingeniería -->
        <div class="mt-16 text-center">
            <p class="text-gray-600 text-xs uppercase tracking-[0.3em]">
                Soporte y Garantía Técnica por <span class="text-gray-400">Hesed Core</span>
            </p>
        </div>
    </div>
</section>