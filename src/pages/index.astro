---
import Layout from '../layouts/Layout.astro';
import Pricing from '../components/Pricing.astro';
import Gallery from '../components/Gallery.astro';
---

<Layout title="TrimmOS - El Núcleo Digital para tu Negocio">
    <!-- BOTÓN FLOTANTE DE WHATSAPP -->
    <a 
        href="https://wa.me/528126076947?text=Hola%20Leonardo!%20Vengo%20de%20la%20web%20y%20quiero%20mi%20mes%20gratis%20de%20TrimmOS%20para%20mi%20negocio" 
        target="_blank" 
        class="fixed bottom-8 right-8 z-50 flex items-center justify-center w-16 h-16 bg-[#25D366] rounded-full shadow-[0_0_20px_rgba(37,211,102,0.4)] hover:scale-110 transition-transform group"
    >
        <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        <span class="absolute right-full mr-4 bg-white text-black text-[10px] font-bold py-2 px-4 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap shadow-xl uppercase tracking-wider">
            ¡Obtén 30 días gratis!
        </span>
    </a>

    <!-- HERO SECTION -->
    <main class="relative min-h-screen flex items-center justify-center overflow-hidden bg-[#070709]">
        <div class="absolute -top-1/4 -left-1/4 w-[600px] h-[600px] bg-purple-600 rounded-full mix-blend-lighten filter blur-[120px] opacity-20"></div>
        <div class="absolute -bottom-1/4 -right-1/4 w-[600px] h-[600px] bg-blue-600 rounded-full mix-blend-lighten filter blur-[120px] opacity-20"></div>

        <div class="relative z-10 text-center px-4 max-w-5xl">
            <h1 class="text-6xl md:text-8xl font-extrabold tracking-tighter mb-6 italic text-white">
                Trimm<span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-pink-600">OS</span>
            </h1>
            <h2 class="text-4xl md:text-6xl font-bold mb-8 leading-tight text-white min-h-[120px] md:min-h-[auto]">
                Domina tu Negocio con <br/> 
                <span id="dynamic-text" class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-pink-600 font-light italic transition-all duration-500 inline-block">
                    Identidad y Control Absoluto
                </span>
            </h2>
            <p class="text-lg md:text-xl text-gray-400 mb-10 leading-relaxed max-w-3xl mx-auto">
                No es solo una agenda. Es el motor multiplataforma que adapta su estilo a tu marca. <strong>Gestiona citas, staff y tu flujo operativo</strong> desde un solo lugar y hacia el siguiente nivel.
            </p>
            
            <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
                <a href="#pricing" class="bg-purple-600 hover:bg-purple-700 text-white px-10 py-4 rounded-2xl font-bold transition-all transform hover:scale-105 shadow-[0_0_20px_rgba(147,51,234,0.3)]">
                    Empezar mi Mes Gratis
                </a>
                <a href="#demo" class="bg-[#16161a] border border-gray-800 hover:border-gray-600 text-white px-10 py-4 rounded-2xl font-bold transition-all">
                    Ver Personalización
                </a>
            </div>
        </div>
    </main>

    <!-- SECCIÓN DE PERSONALIZACIÓN VISUAL -->
    <Gallery />

    <!-- FEATURES SECTION -->
    <section id="features" class="py-20 bg-[#070709]">
        <div class="max-w-5xl mx-auto px-4 grid md:grid-cols-2 gap-12">
            <div class="p-8 rounded-3xl bg-gradient-to-br from-[#16161a] to-[#0a0a0c] border border-gray-800 relative overflow-hidden group">
                <div class="relative z-10">
                    <div class="w-12 h-12 bg-purple-500/10 rounded-xl flex items-center justify-center mb-6">
                        <span class="text-2xl">📸</span>
                    </div>
                    <h3 class="text-2xl font-bold mb-4 text-white">Catálogo Visual Pro</h3>
                    <p class="text-gray-400 leading-relaxed text-sm">
                        Próximamente: Podrás mostrar tu arte antes de la cita. Sube tus degradados y peinados para que tus clientes elijan su estilo ideal.
                    </p>
                    <span class="inline-block mt-4 text-xs font-bold text-purple-400 uppercase tracking-widest">En Desarrollo</span>
                </div>
            </div>

            <div class="p-8 rounded-3xl bg-gradient-to-br from-[#16161a] to-[#0a0a0c] border border-gray-800 relative overflow-hidden group">
                <div class="relative z-10">
                    <div class="w-12 h-12 bg-pink-500/10 rounded-xl flex items-center justify-center mb-6">
                        <span class="text-2xl">🛍️</span>
                    </div>
                    <h3 class="text-2xl font-bold mb-4 text-white">Punto de Venta Integrado</h3>
                    <p class="text-gray-400 leading-relaxed text-sm">
                        Próximamente: Control de stock de ceras, aceites y productos. Un inventario inteligente que te avisará cuando necesites resurtir.
                    </p>
                    <span class="inline-block mt-4 text-xs font-bold text-pink-400 uppercase tracking-widest">Próximamente</span>
                </div>
            </div>
        </div>
    </section>

    <Pricing />

    <!-- FOOTER -->
    <footer class="py-16 border-t border-gray-900 bg-[#070709] text-center">
        <div class="max-w-6xl mx-auto px-4">
            <div class="mb-8">
                <h3 class="text-2xl font-black text-white tracking-[0.15em] italic uppercase">
                    HESED<span class="text-purple-600">CORE</span>
                </h3>
                <p class="text-gray-600 text-[10px] uppercase tracking-[0.4em] mt-2">Engineering with Purpose</p>
            </div>
            <p class="text-gray-500 text-xs">
                &copy; 2026 TrimmOS. Desarrollado con ⚡ en García, NL.
            </p>
        </div>
    </footer>
</Layout>

<script is:inline>
    const phrases = [
        "Identidad y Control Absoluto",
        "Gestión Inteligente de Citas",
        "Automatización de Staff",
        "Reportes en Tiempo Real",
        "Tu Marca, Tus Reglas"
    ];
    
    let currentIndex = 0;
    const textElement = document.getElementById('dynamic-text');

    function changeText() {
        if (!textElement) return;
        
        // Animación de salida
        textElement.style.opacity = '0';
        textElement.style.transform = 'translateY(10px)';

        setTimeout(() => {
            currentIndex = (currentIndex + 1) % phrases.length;
            textElement.textContent = phrases[currentIndex];
            
            // Animación de entrada
            textElement.style.opacity = '1';
            textElement.style.transform = 'translateY(0)';
        }, 500);
    }

    setInterval(changeText, 3500);
</script>